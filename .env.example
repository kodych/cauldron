# Cauldron configuration. Copy to `.env` and adjust.
# All variables are prefixed with CAULDRON_ and read by pydantic-settings.

# --- Neo4j ---------------------------------------------------------------
# Bolt URI of the Neo4j instance Cauldron writes to. The default matches
# the docker-compose service. Switch to a remote bolt+s:// URI if you run
# Neo4j elsewhere.
CAULDRON_NEO4J_URI=bolt://localhost:7687
CAULDRON_NEO4J_USER=neo4j
# CHANGE THIS for any non-local deployment.
CAULDRON_NEO4J_PASSWORD=cauldron

# --- Anthropic Claude ----------------------------------------------------
# Required for `cauldron boil --ai`. Without a key, AI phases skip.
# Key form: sk-ant-api03-...
CAULDRON_ANTHROPIC_API_KEY=

# Model identifier passed to the Anthropic SDK. Pin to a snapshot ID
# (e.g. claude-sonnet-4-5-20250929) for reproducibility, or to an alias
# (e.g. claude-sonnet-4-6) for "always latest of this generation".
CAULDRON_AI_MODEL=claude-sonnet-4-6

# --- NVD API -------------------------------------------------------------
# Optional. With a key, NVD allows ~50 requests / 30 s instead of the
# anonymous ~5 / 30 s — meaningfully faster on large networks. Get one
# at https://nvd.nist.gov/developers/request-an-api-key.
CAULDRON_NVD_API_KEY=

# --- Network --------------------------------------------------------------
# Default subnet width for segmentation. /24 covers the bulk of corporate
# LANs; lower this for /16 flat networks that you want bucketed finer.
CAULDRON_SEGMENT_PREFIX_LEN=24

# --- API server ----------------------------------------------------------
# CORS allowlist. Default covers the Vite dev server (3000) and the API
# itself (8000). Override with a comma-separated list when running the
# UI on a different host or behind a reverse proxy.
# CAULDRON_CORS_ORIGINS=https://cauldron.example.com
