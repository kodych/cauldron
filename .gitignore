# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Environment — actual secrets stay out, the example template is tracked
.env
.env.*
!.env.example
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Neo4j local data
neo4j_data/
neo4j_logs/

# Test / Coverage
.pytest_cache/
htmlcov/
.coverage
tests/private/

# User scan data
data/scans/
*.xml
!data/samples/*.xml

# Documentation — public docs are tracked, the operator-private PROJECT_BIBLE is not
docs/PROJECT_BIBLE.md

# Claude
CLAUDE.md
.claude/

# Operator-local helper scripts — one-off generators, debug harnesses,
# asset-pipeline glue. Never tracked in git: they hard-code local
# absolute paths (D:/Cauldron/...) and reference non-shipped working
# folders. If a helper becomes reusable, promote it to a proper
# cauldron/cli/ command with tests instead of checking it in here.
scripts/
tools/
tmp_*
